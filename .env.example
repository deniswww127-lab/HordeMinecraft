# --- VK (получить на https://dev.vk.com, тип приложения "Веб-сайт") ---
VK_CLIENT_ID=12345678
VK_CLIENT_SECRET=your_secret_here
VK_REDIRECT_URI=https://your-domain.ru/auth/vk/callback
VK_API_VERSION=5.199

# --- LLM (без ключа работает шаблонный фолбэк) ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# --- Инфраструктура ---
DATABASE_URL=sqlite+aiosqlite:///./postpilot.db
SECRET_KEY=replace-with-long-random-string
BASE_URL=https://your-domain.ru

POST_RATE_LIMIT_SECONDS=30
